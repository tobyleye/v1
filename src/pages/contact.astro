---
import Layout from "../layouts/Layout.astro";

const [formData, setFormData] = [
  {
    name: "",
    email: "",
    message: "",
  },
  () => {},
];
const [isSubmitted, setIsSubmitted] = [false, () => {}];

const handleChange = (
  e: React.ChangeEvent<HTMLInputElement | HTMLTextAreaElement>,
) => {
  const { name, value } = e.target;
  setFormData((prev) => ({
    ...prev,
    [name]: value,
  }));
};

const handleSubmit = (e: FormEvent) => {
  e.preventDefault();
  // Here you would typically send the form data to a backend
  console.log("Form submitted:", formData);
  setIsSubmitted(true);
  setTimeout(() => {
    setIsSubmitted(false);
    setFormData({ name: "", email: "", message: "" });
  }, 3000);
};
---

<Layout>
  <main
    class="min-h-screen bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950"
  >
    <div class="pt-32 pb-20 px-6">
      <div class="max-w-2xl mx-auto page-transition-in">
        <section>
          <div class="mb-16">
            <h1 class="text-4xl md:text-5xl font-bold text-foreground mb-4">
              Let's Connect
            </h1>
            <p class="text-foreground/60 text-lg">
              Have a project in mind or just want to chat? Feel free to reach
              out.
            </p>
          </div>

          <div class="space-y-12">
            {/* Contact Form */}
            <div>
              <form onSubmit={handleSubmit} class="space-y-6">
                <div>
                  <label
                    htmlFor="name"
                    class="block text-sm font-medium text-foreground mb-2"
                  >
                    Name
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    value={formData.name}
                    onChange={handleChange}
                    required
                    class="w-full px-4 py-2 bg-slate-800/50 border border-foreground/20 rounded-md text-foreground placeholder-foreground/40 focus:outline-none focus:border-foreground/50 transition-colors"
                    placeholder="Your name"
                  />
                </div>

                <div>
                  <label
                    htmlFor="email"
                    class="block text-sm font-medium text-foreground mb-2"
                  >
                    Email
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    value={formData.email}
                    onChange={handleChange}
                    required
                    class="w-full px-4 py-2 bg-slate-800/50 border border-foreground/20 rounded-md text-foreground placeholder-foreground/40 focus:outline-none focus:border-foreground/50 transition-colors"
                    placeholder="your@email.com"
                  />
                </div>

                <div>
                  <label
                    htmlFor="message"
                    class="block text-sm font-medium text-foreground mb-2"
                  >
                    Message
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    value={formData.message}
                    onChange={handleChange}
                    required
                    rows={6}
                    class="w-full px-4 py-2 bg-slate-800/50 border border-foreground/20 rounded-md text-foreground placeholder-foreground/40 focus:outline-none focus:border-foreground/50 transition-colors resize-none"
                    placeholder="Your message..."></textarea>
                </div>

                <button
                  type="submit"
                  class="w-full px-6 py-3 bg-foreground text-background rounded-md font-medium hover:opacity-90 transition-opacity"
                >
                  {isSubmitted ? "Message Sent!" : "Send Message"}
                </button>
              </form>
            </div>

            {/* Other Contact Methods */}
            <div class="border-t border-foreground/10 pt-12 space-y-8">
              <div>
                <h3
                  class="text-sm font-semibold text-foreground/60 uppercase tracking-wider mb-4"
                >
                  Contact Methods
                </h3>
                <div class="space-y-3">
                  <div>
                    <p class="text-foreground/60 text-sm mb-1">Email</p>
                    <a
                      href="mailto:hello@example.com"
                      class="text-foreground hover:text-foreground/80 transition-colors"
                    >
                      hello@example.com
                    </a>
                  </div>
                  <div>
                    <p class="text-foreground/60 text-sm mb-1">LinkedIn</p>
                    <a
                      href="#"
                      class="text-foreground hover:text-foreground/80 transition-colors"
                    >
                      linkedin.com/in/yourprofile
                    </a>
                  </div>
                  <div>
                    <p class="text-foreground/60 text-sm mb-1">GitHub</p>
                    <a
                      href="#"
                      class="text-foreground hover:text-foreground/80 transition-colors"
                    >
                      github.com/yourprofile
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>
